{
  "annotations": {
    "list": [
      {
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Deployments",
        "type": "dashboard"
      }
    ]
  },
  "description": "PiggyMetrics Application Overview — Golden Signals per service",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🚦 Traffic Overview",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "title": "Requests per Second (by service)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"piggymetrics\"}[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "title": "Error Rate (5xx) per Service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"piggymetrics\", code=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total{namespace=\"piggymetrics\"}[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "⏱️ Latency",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "title": "P50 Latency (by service)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"piggymetrics\"}[5m])) by (le, service))",
          "legendFormat": "{{service}} p50"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "title": "P99 Latency (by service)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"piggymetrics\"}[5m])) by (le, service))",
          "legendFormat": "{{service}} p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "🔥 Saturation",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "title": "CPU Usage vs Limit",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"piggymetrics\", container!=\"\"}[5m])) by (pod) / sum(container_spec_cpu_quota{namespace=\"piggymetrics\", container!=\"\"}/container_spec_cpu_period{namespace=\"piggymetrics\", container!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "title": "Memory Usage vs Limit",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"piggymetrics\", container!=\"\"}) by (pod) / sum(container_spec_memory_limit_bytes{namespace=\"piggymetrics\", container!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 10,
      "title": "📊 Service Health",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" } }, "type": "value" },
            { "options": { "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 28 },
      "id": 11,
      "title": "Service Up/Down Status",
      "type": "stat",
      "targets": [
        {
          "expr": "up{namespace=\"piggymetrics\"}",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 32 },
      "id": 12,
      "title": "Pod Restart Count (last 1h)",
      "type": "bargauge",
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"piggymetrics\"}[1h])",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 32 },
      "id": 13,
      "title": "Active Connections (by service)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(http_server_requests_active{namespace=\"piggymetrics\"}) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["piggymetrics", "golden-signals", "sre"],
  "templating": {
    "list": [
      {
        "definition": "label_values(http_requests_total{namespace=\"piggymetrics\"}, service)",
        "name": "service",
        "type": "query",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "PiggyMetrics — Application Overview (Golden Signals)",
  "uid": "piggymetrics-golden-signals"
}
